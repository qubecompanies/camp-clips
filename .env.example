# Camp Clips — build-time environment variables (Vite).
# Copy this to .env.production (gitignored) and fill in real values, then build.

# Error-telemetry endpoint (the deployed Cloudflare Worker's /report URL).
# Leave unset to disable error reporting entirely — the client is a no-op without it.
VITE_TELEMETRY_URL=https://camp-clips-telemetry.qubecompanies.workers.dev/report
